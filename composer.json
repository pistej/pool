{
    "name": "sfrpc/pool",
    "description": "A high-performance, zero-dependency Swoole gRPC connection pool and bundle for Symfony.",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "ext-swoole": "*",
        "google/protobuf": "^4.26",
        "symfony/config": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/http-kernel": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^3.9",
        "swoole/ide-helper": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Sfrpc\\Pool\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sfrpc\\Pool\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}